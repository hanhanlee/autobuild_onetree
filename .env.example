# ============================================================
# Autobuild Onetree - Environment Variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# After editing: chmod 600 .env && chown autobuild:scm-bmc .env
#
# NOTE: AUTOBUILD_WORKSPACE_ROOT / AUTOBUILD_JOBS_ROOT / AUTOBUILD_DB are
# already set inside systemd/autobuild.service. Because load_dotenv() does
# NOT override existing env vars, changing those three here has no effect
# on the systemd-managed instance. Use a systemd override instead.
# ============================================================

# ---------- Required ----------

# Random long string. Used for session cookie signing. Rotate per host.
AUTOBUILD_SECRET_KEY=replace-with-a-long-random-secret

# Linux group whose members may log in via PAM.
AUTOBUILD_ALLOWED_GROUP=scm-bmc

# Internal GitLab host (no scheme).
AUTOBUILD_GIT_HOST=gitlab.example.com

# ---------- Recommended ----------

# Hostname / IP shown in the "Copy SSH command" button in the jobs UI.
# If unset, the app falls back to socket.gethostname().
# On the standby host, set this to the standby's hostname/IP.
AUTOBUILD_SSH_HOST=

# Display timezone for timestamps in the UI.
AUTOBUILD_TIMEZONE=Asia/Taipei

# Polling interval (ms) for live job log refresh in the UI.
AUTOBUILD_LOG_POLLING_MS=1000

# Background housekeeping interval (seconds).
AUTOBUILD_HOUSEKEEPING_INTERVAL=3600

# Disk free-space alert threshold (GB) for the dashboard.
AUTOBUILD_DISK_MIN_FREE_GB=5

# Build hard timeout (seconds). Default 21600 = 6h.
AUTOBUILD_BUILD_TIMEOUT=21600

# Max concurrent jobs.
AUTOBUILD_MAX_CONCURRENT_JOBS=3

# ---------- Optional: subpath deployment ----------

# Set when Autobuild is served behind a reverse proxy under a subpath
# (e.g. https://gateway/autobuild/). Leave empty for root mounting.
# AUTOBUILD_BASE_PATH=/autobuild

# ---------- Optional: workspace overrides ----------
# Only useful when NOT using the systemd unit (see note at top of file).
# AUTOBUILD_WORKSPACE_ROOT=/work/autobuild_workspace
# AUTOBUILD_JOBS_ROOT=/work/autobuild_workspace/jobs
# AUTOBUILD_DB=/work/autobuild_workspace/data/jobs.db

# ---------- Optional: cleanup paths ----------
# Only used by the Settings cleanup page.
# SSTATE_DIR=/work/sstate-cache
# DL_DIR=/work/downloads

# ---------- Optional: SMTP (build notifications) ----------
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
